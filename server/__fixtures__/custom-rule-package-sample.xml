        <Term caseSensitive="false">passport</Term>
        <Term caseSensitive="false">australia</Term>
      </Group>
    </Keyword>
    <LocalizedStrings>
      <Resource idRef="cccccccc-cccc-4ccc-8ccc-cccccccccccc">
